#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local src="${BASH_SOURCE[0]}"
  while [[ -h "$src" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd
}

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

strip_wrapping_quotes() {
  local v="$1"
  if [[ "$v" =~ ^\"(.*)\"$ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return
  fi
  if [[ "$v" =~ ^\'(.*)\'$ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return
  fi
  printf '%s' "$v"
}

to_lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

load_kv_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="$(trim "$line")"
    [[ -z "$line" || "${line:0:1}" == "#" ]] && continue

    if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
      local key="${BASH_REMATCH[1]}"
      local value="${BASH_REMATCH[2]}"
      value="$(trim "$value")"
      value="$(strip_wrapping_quotes "$value")"
      export "$key=$value"
    fi
  done < "$file"
}

if [[ -n "${MK42_HOME:-}" ]]; then
  MK42_HOME="$MK42_HOME"
else
  SCRIPT_DIR="$(resolve_script_path)"
  MK42_HOME=""

  for candidate_rel in "../.." "../../.."; do
    candidate="$(cd "$SCRIPT_DIR/$candidate_rel" >/dev/null 2>&1 && pwd || true)"
    if [[ -n "$candidate" && ( -e "$candidate/current" || -d "$candidate/releases" ) ]]; then
      MK42_HOME="$candidate"
      break
    fi
  done

  if [[ -z "$MK42_HOME" ]]; then
    MK42_HOME="$HOME/.agents/mk42"
  fi
fi

DEFAULT_ENV_FILE="$HOME/.agents/flatmachines/mk42.env"
DEFAULT_CODEX_AUTH_FILE="$HOME/.agents/flatmachines/auth.json"

CONF_FILE="${MK42_CONF:-$MK42_HOME/conf}"
load_kv_file "$CONF_FILE"

ENV_FILE="${MK42_ENV_FILE:-$DEFAULT_ENV_FILE}"
load_kv_file "$ENV_FILE"

MK42_CODEX_AUTH_FILE="${MK42_CODEX_AUTH_FILE:-$DEFAULT_CODEX_AUTH_FILE}"
FLATAGENTS_CODEX_AUTH_FILE="${FLATAGENTS_CODEX_AUTH_FILE:-$MK42_CODEX_AUTH_FILE}"

CURRENT_DIR="$MK42_HOME/current"
VENV_PYTHON="$MK42_HOME/.venv/bin/python"

DEFAULT_CONFIG_DIR="${TOOL_USE_DISCORD_CONFIG_DIR:-$CURRENT_DIR/config}"
DEFAULT_DB_PATH="${TOOL_USE_DISCORD_DB_PATH:-$CURRENT_DIR/data/coding_machine_discord.sqlite}"
DEFAULT_WORKING_DIR="${TOOL_USE_DISCORD_WORKING_DIR:-$CURRENT_DIR}"
DEFAULT_CHAT_ROLLOVER_TOKEN_LIMIT="${MK42_CHAT_ROLLOVER_TOKEN_LIMIT:-50000}"

mkdir -p "$CURRENT_DIR/data" "$MK42_HOME/logs"

export MK42_HOME
export MK42_CONF="$CONF_FILE"
export MK42_ENV_FILE="$ENV_FILE"
export MK42_CODEX_AUTH_FILE
export FLATAGENTS_CODEX_AUTH_FILE
export TOOL_USE_DISCORD_CONFIG_DIR="$DEFAULT_CONFIG_DIR"
export TOOL_USE_DISCORD_DB_PATH="$DEFAULT_DB_PATH"
export TOOL_USE_DISCORD_WORKING_DIR="$DEFAULT_WORKING_DIR"
export MK42_CHAT_ROLLOVER_TOKEN_LIMIT="$DEFAULT_CHAT_ROLLOVER_TOKEN_LIMIT"

if [[ ! -e "$CURRENT_DIR" ]]; then
  echo "error: mk42 is not installed at $MK42_HOME (missing current symlink)" >&2
  echo "run installer first (install.sh --dir '$MK42_HOME')" >&2
  exit 1
fi

if [[ ! -f "$TOOL_USE_DISCORD_CONFIG_DIR/discord_machine.yml" ]]; then
  echo "error: missing config in $TOOL_USE_DISCORD_CONFIG_DIR" >&2
  exit 1
fi

if [[ ! -x "$VENV_PYTHON" ]]; then
  echo "error: python runtime not found at $VENV_PYTHON" >&2
  echo "run installer again to provision the virtualenv" >&2
  exit 1
fi

has_flag() {
  local flag="$1"
  shift
  for arg in "$@"; do
    if [[ "$arg" == "$flag" || "$arg" == "$flag="* ]]; then
      return 0
    fi
  done
  return 1
}

run_codex_login() {
  local target="$MK42_CODEX_AUTH_FILE"
  mkdir -p "$(dirname "$target")"

  if [[ -s "$target" ]]; then
    chmod 600 "$target" || true
    echo "Codex auth already configured: $target"
    return 0
  fi

  local login_mode="${MK42_CODEX_LOGIN_MODE:-manual}"
  local login_args=(--auth-file "$target")

  case "$login_mode" in
    manual)
      login_args+=(--no-browser --no-local-server)
      ;;
    browser)
      ;;
    *)
      echo "error: invalid MK42_CODEX_LOGIN_MODE: $login_mode (expected: manual or browser)" >&2
      return 1
      ;;
  esac

  echo "Running FlatAgents Codex OAuth login..."
  echo "Mode: $login_mode"
  echo "Command: $VENV_PYTHON -m flatagents.providers.openai_codex_login ${login_args[*]}"

  if ! "$VENV_PYTHON" -m flatagents.providers.openai_codex_login "${login_args[@]}"; then
    echo "error: FlatAgents Codex login module failed" >&2
    return 1
  fi

  if [[ -s "$target" ]]; then
    chmod 600 "$target" || true
    echo "Codex auth configured: $target"
    return 0
  fi

  echo "error: Codex login finished, but auth file was not found." >&2
  echo "Expected target: $target" >&2
  echo "Rerun mk42 login codex and complete the OAuth flow." >&2
  return 1
}

has_tty() {
  if (exec 9<>/dev/tty) 2>/dev/null; then
    exec 9>&- 9<&-
    return 0
  fi
  return 1
}

mask_value() {
  local value="$1"
  local n=${#value}
  if [[ $n -le 8 ]]; then
    printf '********'
    return
  fi
  printf '%s***%s' "${value:0:4}" "${value:$((n-4)):4}"
}

set_kv_file_value() {
  local file="$1"
  local key="$2"
  local value="$3"

  "$VENV_PYTHON" - <<'PY' "$file" "$key" "$value"
from pathlib import Path
import re
import sys

path = Path(sys.argv[1]).expanduser().resolve()
key = sys.argv[2]
value = sys.argv[3]

path.parent.mkdir(parents=True, exist_ok=True)
if path.exists():
    lines = path.read_text(encoding='utf-8').splitlines()
else:
    lines = []

pattern = re.compile(rf'^{re.escape(key)}\s*=')
replaced = False
out = []
for line in lines:
    if pattern.match(line.strip()):
        out.append(f"{key}={value}")
        replaced = True
    else:
        out.append(line)

if not replaced:
    if out and out[-1].strip() != "":
        out.append("")
    out.append(f"{key}={value}")

path.write_text("\n".join(out).rstrip() + "\n", encoding='utf-8')
PY
}

get_discord_admin_ids_csv() {
  mkdir -p "$(dirname "$TOOL_USE_DISCORD_DB_PATH")"

  "$VENV_PYTHON" - <<'PY' "$TOOL_USE_DISCORD_DB_PATH"
from pathlib import Path
import sqlite3
import sys

db_path = Path(sys.argv[1]).expanduser().resolve()
db_path.parent.mkdir(parents=True, exist_ok=True)

conn = sqlite3.connect(str(db_path))
conn.row_factory = sqlite3.Row
conn.execute(
    """
    CREATE TABLE IF NOT EXISTS discord_users (
        user_id TEXT PRIMARY KEY,
        username TEXT,
        is_admin INTEGER NOT NULL DEFAULT 0,
        updated_at REAL NOT NULL
    )
    """
)
rows = conn.execute(
    "SELECT user_id FROM discord_users WHERE is_admin = 1 ORDER BY updated_at DESC, user_id ASC"
).fetchall()
print(",".join(str(row["user_id"]) for row in rows))
PY
}

get_discord_admin_count() {
  mkdir -p "$(dirname "$TOOL_USE_DISCORD_DB_PATH")"

  "$VENV_PYTHON" - <<'PY' "$TOOL_USE_DISCORD_DB_PATH"
from pathlib import Path
import sqlite3
import sys

db_path = Path(sys.argv[1]).expanduser().resolve()
db_path.parent.mkdir(parents=True, exist_ok=True)

conn = sqlite3.connect(str(db_path))
conn.row_factory = sqlite3.Row
conn.execute(
    """
    CREATE TABLE IF NOT EXISTS discord_users (
        user_id TEXT PRIMARY KEY,
        username TEXT,
        is_admin INTEGER NOT NULL DEFAULT 0,
        updated_at REAL NOT NULL
    )
    """
)
row = conn.execute("SELECT COUNT(*) AS n FROM discord_users WHERE is_admin = 1").fetchone()
print(int(row["n"] if row is not None else 0))
PY
}

upsert_discord_admin_ids() {
  local raw="$1"
  mkdir -p "$(dirname "$TOOL_USE_DISCORD_DB_PATH")"

  "$VENV_PYTHON" - <<'PY' "$TOOL_USE_DISCORD_DB_PATH" "$raw"
from pathlib import Path
import re
import sqlite3
import sys
import time

db_path = Path(sys.argv[1]).expanduser().resolve()
raw = sys.argv[2]

tokens = [token for token in re.split(r"[,\s]+", raw.strip()) if token]
admin_ids: list[str] = []
for token in tokens:
    mention = re.fullmatch(r"<@!?(\d+)>", token)
    if mention:
        token = mention.group(1)
    if token.isdigit() and token not in admin_ids:
        admin_ids.append(token)

if not admin_ids:
    print(
        "error: provide at least 1 valid Discord user ID (for admin; digits, comma/space separated, or <@...> mention)",
        file=sys.stderr,
    )
    raise SystemExit(2)

conn = sqlite3.connect(str(db_path))
conn.row_factory = sqlite3.Row
conn.execute(
    """
    CREATE TABLE IF NOT EXISTS discord_users (
        user_id TEXT PRIMARY KEY,
        username TEXT,
        is_admin INTEGER NOT NULL DEFAULT 0,
        updated_at REAL NOT NULL
    )
    """
)

now = time.time()
for user_id in admin_ids:
    conn.execute(
        """
        INSERT INTO discord_users(user_id, username, is_admin, updated_at)
        VALUES (?, NULL, 1, ?)
        ON CONFLICT(user_id) DO UPDATE SET
            is_admin = 1,
            updated_at = excluded.updated_at
        """,
        (user_id, now),
    )

conn.commit()
print(",".join(admin_ids))
PY
}

prompt_tty_value() {
  local label="$1"
  local current="$2"
  local secret="$3"
  local input=""

  if [[ -n "$current" ]]; then
    if [[ "$secret" == "true" ]]; then
      printf '%s [current: %s]: ' "$label" "$(mask_value "$current")" >/dev/tty
    else
      printf '%s [current: %s]: ' "$label" "$current" >/dev/tty
    fi
  else
    printf '%s: ' "$label" >/dev/tty
  fi

  if [[ "$secret" == "true" ]]; then
    IFS= read -r -s input </dev/tty || input=""
    printf '\n' >/dev/tty
  else
    IFS= read -r input </dev/tty || input=""
  fi

  if [[ -z "$input" ]]; then
    printf '%s' "$current"
  else
    printf '%s' "$input"
  fi
}

prompt_tty_raw() {
  local label="$1"
  local current="$2"
  local input=""

  if [[ -n "$current" ]]; then
    printf '%s [current: %s]: ' "$label" "$current" >/dev/tty
  else
    printf '%s: ' "$label" >/dev/tty
  fi

  IFS= read -r input </dev/tty || input=""
  if [[ -z "$input" ]]; then
    printf '%s' "$current"
  else
    printf '%s' "$input"
  fi
}

run_discord_admin_setup() {
  if ! has_tty; then
    echo "error: Discord admin setup requires an interactive TTY." >&2
    echo "Edit DB manually: $TOOL_USE_DISCORD_DB_PATH (discord_users table)" >&2
    return 1
  fi

  local current_admins
  current_admins="$(get_discord_admin_ids_csv)"

  cat >/dev/tty <<EOF

Discord admin setup
  DB path: $TOOL_USE_DISCORD_DB_PATH

Add at least 1 Discord user ID (for admin).
Accepted input: comma/space separated Discord user IDs (or <@...> mentions).

How to get Discord user IDs:
  1) Enable Developer Mode in Discord settings
  2) Right-click user -> Copy User ID
  Docs: https://support.discord.com/hc/en-us/articles/206346498
EOF

  local admins_input=""
  local saved=""

  while true; do
    admins_input="$(prompt_tty_raw "DISCORD_ADMIN_USER_IDS" "$current_admins")"

    if [[ -z "$(trim "$admins_input")" ]]; then
      echo "Please provide at least 1 Discord user ID (for admin)." >/dev/tty
      continue
    fi

    if saved="$(upsert_discord_admin_ids "$admins_input" 2>&1)"; then
      break
    fi

    printf '%s\n' "$saved" >/dev/tty
  done

  echo "Saved Discord admin IDs: $saved"
}

run_discord_setup() {
  if ! has_tty; then
    echo "error: Discord setup requires an interactive TTY." >&2
    echo "Edit env file manually: $ENV_FILE" >&2
    return 1
  fi

  mkdir -p "$(dirname "$ENV_FILE")"
  if [[ ! -f "$ENV_FILE" ]]; then
    cat > "$ENV_FILE" <<'EOF'
# mk42 runtime environment
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
CODING_MACHINE_DISCORD_DEBUG=true
EOF
    chmod 600 "$ENV_FILE" || true
  fi

  local current_token="${DISCORD_BOT_TOKEN:-}"
  local current_channel="${DISCORD_CHANNEL_ID:-}"

  cat >/dev/tty <<EOF

Discord setup
  Env file: $ENV_FILE

How to get DISCORD_BOT_TOKEN:
  1) Open Discord Developer Portal: https://discord.com/developers/applications
  2) Select your app -> Bot -> Reset Token / Copy Token

How to get DISCORD_CHANNEL_ID:
  1) Enable Developer Mode in Discord settings
  2) Right-click channel -> Copy Channel ID
  Docs: https://support.discord.com/hc/en-us/articles/206346498

Leave a field empty to keep current value.
EOF

  local token
  local channel
  token="$(prompt_tty_value "DISCORD_BOT_TOKEN" "$current_token" true)"
  channel="$(prompt_tty_value "DISCORD_CHANNEL_ID" "$current_channel" false)"

  if [[ -n "$token" ]]; then
    set_kv_file_value "$ENV_FILE" "DISCORD_BOT_TOKEN" "$token"
  fi
  if [[ -n "$channel" ]]; then
    set_kv_file_value "$ENV_FILE" "DISCORD_CHANNEL_ID" "$channel"
  fi

  set_kv_file_value "$ENV_FILE" "CODING_MACHINE_DISCORD_DEBUG" "${CODING_MACHINE_DISCORD_DEBUG:-true}"

  # Refresh current process environment from the updated env file.
  load_kv_file "$ENV_FILE"
  export DISCORD_BOT_TOKEN="${DISCORD_BOT_TOKEN:-}"
  export DISCORD_CHANNEL_ID="${DISCORD_CHANNEL_ID:-}"

  if ! run_discord_admin_setup; then
    return 1
  fi

  echo "Saved Discord settings to $ENV_FILE"
  echo "Saved Discord admins to $TOOL_USE_DISCORD_DB_PATH"
  echo "Next: mk42 all"
}

run_full_setup() {
  local rc=0

  if ! run_codex_login; then
    rc=1
  fi

  if ! run_discord_setup; then
    rc=1
  fi

  if [[ $rc -eq 0 ]]; then
    echo "mk42 setup complete."
    echo "Run: mk42 all"
  else
    echo "mk42 setup finished with issues." >&2
    echo "You can retry pieces individually:" >&2
    echo "  mk42 login codex" >&2
    echo "  mk42 setup discord" >&2
  fi

  return $rc
}

missing_setup_items() {
  local items=()

  if [[ ! -s "$MK42_CODEX_AUTH_FILE" ]]; then
    items+=("codex_auth")
  fi

  if [[ -z "${DISCORD_BOT_TOKEN:-}" ]]; then
    items+=("discord_bot_token")
  fi

  if [[ -z "${DISCORD_CHANNEL_ID:-}" ]]; then
    items+=("discord_channel_id")
  fi

  if [[ "$(get_discord_admin_count)" == "0" ]]; then
    items+=("discord_admin_user_ids")
  fi

  printf '%s\n' "${items[@]}"
}

command_needs_setup() {
  case "$1" in
    all|cli|respond|ingress)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

auto_setup_if_needed() {
  local cmd="$1"
  local skip_setup="$2"

  if ! command_needs_setup "$cmd"; then
    return 0
  fi

  local missing
  missing="$(missing_setup_items)"
  if [[ -z "$missing" ]]; then
    return 0
  fi

  if [[ "$skip_setup" == "true" ]]; then
    echo "warning: --skip-setup provided, but setup is incomplete:" >&2
    printf '%s\n' "$missing" | sed 's/^/  - /' >&2
    return 0
  fi

  echo "Setup required before running '$cmd'. Missing:" >&2
  printf '%s\n' "$missing" | sed 's/^/  - /' >&2

  if ! has_tty; then
    echo "error: setup requires an interactive TTY." >&2
    echo "Run interactively: mk42 setup" >&2
    echo "Or bypass with: --skip-setup" >&2
    return 1
  fi

  echo "Running: mk42 setup"
  run_full_setup
}

print_help() {
  cat <<EOF
mk42

Usage:
  mk42 [--skip-setup] [command] [args]

Commands:
  setup [all|discord|codex]  Run onboarding setup (codex + Discord env + admin IDs)
  login codex                Run Codex OAuth login only
  all                        Run ingress + debounce + respond
  ingress                    Run ingress worker
  debounce                   Run debounce worker
  respond                    Run responder worker
  status                     Show queue stats
  cli                        Run CLI mode
  start                      Alias for 'all'
  run                        Alias for 'all'
  restart                    Restart and run 'all'

Options:
  -h, --help                 Show this help
  --skip-setup               Skip automatic setup checks/prompts

Notes:
  - Running 'mk42' with no command is the same as 'mk42 all'.
  - Setup requires Codex auth, Discord token/channel, and at least 1 Discord user ID (for admin).
  - If setup is incomplete, mk42 auto-runs 'mk42 setup' for commands that need it.
EOF
}

SKIP_SETUP="false"
FILTERED_ARGS=()
for arg in "$@"; do
  case "$arg" in
    -h|--help)
      print_help
      exit 0
      ;;
    --skip-setup)
      SKIP_SETUP="true"
      ;;
    *)
      FILTERED_ARGS+=("$arg")
      ;;
  esac
done

set -- "${FILTERED_ARGS[@]}"

cmd="${1:-all}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$cmd" in
  run|start)
    cmd="all"
    ;;
  restart)
    pkill -f "tool_use_discord.main" || true
    sleep 1
    cmd="all"
    ;;
  login)
    provider="${1:-codex}"
    if [[ "$provider" != "codex" ]]; then
      echo "error: unknown login provider '$provider' (supported: codex)" >&2
      exit 1
    fi
    run_codex_login
    exit $?
    ;;
  setup)
    target="${1:-all}"
    case "$target" in
      all)
        run_full_setup
        exit $?
        ;;
      discord)
        run_discord_setup
        exit $?
        ;;
      codex)
        run_codex_login
        exit $?
        ;;
      *)
        echo "error: unknown setup target '$target' (supported: all|discord|codex)" >&2
        exit 1
        ;;
    esac
    ;;
  cli|ingress|debounce|respond|all|status)
    ;;
  *)
    echo "error: unknown command '$cmd'" >&2
    echo "usage: mk42 [setup [all|discord|codex]|login codex|cli|ingress|debounce|respond|all|status|start|restart] [args...]" >&2
    exit 1
    ;;
esac

if ! auto_setup_if_needed "$cmd" "$SKIP_SETUP"; then
  exit 1
fi

args=("$cmd" "$@")

if [[ "$cmd" == "ingress" || "$cmd" == "debounce" || "$cmd" == "respond" || "$cmd" == "all" || "$cmd" == "status" ]]; then
  if ! has_flag "--db-path" "$@"; then
    args+=("--db-path" "$TOOL_USE_DISCORD_DB_PATH")
  fi
fi

if [[ "$cmd" == "cli" || "$cmd" == "respond" || "$cmd" == "all" ]]; then
  if ! has_flag "--working-dir" "$@" && ! has_flag "-w" "$@"; then
    args+=("--working-dir" "$TOOL_USE_DISCORD_WORKING_DIR")
  fi
fi

DEBUG_MODE="${CODING_MACHINE_DISCORD_DEBUG:-true}"
DEBUG_MODE_LOWER="$(to_lower "$DEBUG_MODE")"
if [[ "$DEBUG_MODE_LOWER" == "0" || "$DEBUG_MODE_LOWER" == "false" || "$DEBUG_MODE_LOWER" == "no" || "$DEBUG_MODE_LOWER" == "off" ]]; then
  exec "$VENV_PYTHON" -u -m tool_use_discord.main "${args[@]}"
else
  LOG_LEVEL=DEBUG FLATAGENTS_LOG_LEVEL=DEBUG exec "$VENV_PYTHON" -u -m tool_use_discord.main "${args[@]}"
fi
