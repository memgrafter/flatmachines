{
  "name": "flatagents-js-workspace",
  "version": "2.5.0",
  "private": true,
  "description": "JavaScript SDK workspace for FlatAgents and FlatMachines",
  "workspaces": [
    "packages/flatagents",
    "packages/flatmachines"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:agents": "npm run build -w packages/flatagents",
    "build:machines": "npm run build -w packages/flatmachines",
    "typecheck": "npm run typecheck --workspaces",
    "typecheck:agents": "npm run typecheck -w packages/flatagents",
    "typecheck:machines": "npm run typecheck -w packages/flatmachines",
    "test": "vitest run",
    "dev": "npm run build --workspaces -- --watch"
  },
  "author": "memgrafter@gmail.com",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@types/nunjucks": "^3.2.6",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
